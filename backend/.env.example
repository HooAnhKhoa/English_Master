# ============================================================
# SERVER CONFIGURATION
# ============================================================
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ============================================================
# DATABASE CONFIGURATION (MySQL)
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=englishmaster
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_key
JWT_REFRESH_EXPIRE=30d

# ============================================================
# GOOGLE OAUTH 2.0
# ============================================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ============================================================
# CLOUDINARY (Image/Audio Upload)
# ============================================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================================
# OPENAI API (AI Conversation)
# ============================================================
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# ============================================================
# REDIS CONFIGURATION (Cache & Rate Limit)
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ============================================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=EnglishMaster <noreply@englishmaster.com>

# ============================================================
# FRONTEND URL (CORS)
# ============================================================
FRONTEND_URL=http://localhost:3000

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# FILE UPLOAD LIMITS
# ============================================================
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg,audio/mpeg,audio/wav

# ============================================================
# SESSION SECRET
# ============================================================
SESSION_SECRET=your_session_secret_key_change_this

# ============================================================
# SOCKET.IO
# ============================================================
SOCKET_CORS_ORIGIN=http://localhost:3000

# ============================================================
# PAGINATION DEFAULTS
# ============================================================
DEFAULT_PAGE=1
DEFAULT_LIMIT=20
MAX_LIMIT=100

# ============================================================
# PASSWORD RESET
# ============================================================
RESET_PASSWORD_EXPIRE=3600000
